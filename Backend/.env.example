

# Django secret key (generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your-secret-key-here

# Set to True for local development, False for production
DEBUG=True

# Comma-separated list of allowed hostnames.
# For phone/LAN testing, add your PC IP, e.g. 192.168.1.100.
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.100

# For phone/LAN testing, allow your frontend origin.
CORS_ORIGINS=http://192.168.1.100:5173
CSRF_TRUSTED_ORIGINS=http://192.168.1.100:5173

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:your-password-here@localhost:5432/plmundb

# Production cache / WebSocket channel layer. Leave commented for local dev
# unless Redis is running.
# REDIS_URL=redis://localhost:6379/0

# Production HTTPS/cookie options
SECURE_SSL_REDIRECT=False
REFRESH_COOKIE_SAMESITE=Lax
ALLOWED_EMAIL_DOMAINS=plmun.edu.ph

# Optional: fixed demo password for `seed_demo`. If unset, local dev (DEBUG=True)
# uses 'demo_pass_2026' and production generates a random one.
# DEMO_PASSWORD=replace-with-a-demo-only-password

# ===== Messages Assistant =====
# Provider for the read-only Messages assistant: "ollama" (local, free, for
# development) or "gemini" (cloud, for production). Defaults to "gemini".
ASSISTANT_PROVIDER=ollama

# Ollama (local dev) — install from https://ollama.com, then:
#   ollama pull qwen2.5:7b-instruct && ollama serve
# qwen2.5:7b-instruct suits a ~6 GB-VRAM GPU (e.g. RTX 4050 laptop). For a
# weaker GPU use qwen2.5:3b-instruct; for more headroom try llama3.1:8b.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ALLOWED_HOSTS=localhost,127.0.0.1,::1
OLLAMA_MODEL=qwen2.5:7b-instruct
# Prompt context window (tokens). Higher = more memory but fits longer prompts.
OLLAMA_NUM_CTX=4096
OLLAMA_TIMEOUT=30

# Gemini (production) — used when ASSISTANT_PROVIDER=gemini.
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash
