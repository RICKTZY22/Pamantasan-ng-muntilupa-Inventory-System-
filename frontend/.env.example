# Local laptop only:
# VITE_API_URL=http://localhost:8000/api

# Phone/LAN testing: replace with your PC Wi-Fi IP.
VITE_API_URL=http://192.168.1.100:8000/api

# Production:
# VITE_API_URL=https://your-api-domain.example/api

# Set to 'true' to show clickable demo-credentials on the Login page.
# Pair with `python manage.py seed_demo` on the backend.
# Leave unset (or set to 'false') for production deployments.
# VITE_DEMO_MODE=true
# Match the backend demo password (local dev default below; set yours if overridden).
# VITE_DEMO_PASSWORD=demo_pass_2026
